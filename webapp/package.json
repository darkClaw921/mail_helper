{
  "name": "mail-helper-webapp",
  "version": "0.1.0",
  "private": true,
  "description": "Mail Helper backend + web UI: IMAP listener, LLM classifier, actions, WS hub",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --watch server server/index.js",
    "dev:client": "vite",
    "start": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "init-db": "node server/db/init.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "imapflow": "^1.3.1",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
